//@version=5
indicator("Triple Sweep System — PDH / Session / Swing", overlay=true, max_bars_back=1000)

// ══ Settings ══════════════════════════════════
swingLen = input.int(8,    "Swing Lookback (bars)")
rsiOB    = input.int(58,   "RSI Overbought (Short)")
rsiOS    = input.int(42,   "RSI Oversold  (Long)")
cooldown = input.int(12,   "Cooldown bars")
minWick  = input.float(0.2,"Min Wick / ATR", step=0.05)

// ══ Indicators ════════════════════════════════
atr = ta.atr(14)
rsi = ta.rsi(close, 14)

// ══ 1. PDH / PDL ══════════════════════════════
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_off)

// ══ 2. Session Ranges (UTC) ═══════════════════
inAsia = not na(time("5", "0000-0700", "UTC"))
inLon  = not na(time("5", "0700-1330", "UTC"))
inNY   = not na(time("5", "1330-2000", "UTC"))

asiaEnd   = not inAsia and inAsia[1]
lonEnd    = not inLon  and inLon[1]

var float asiaH = na, asiaL = na
var float lonH  = na, lonL  = na
var float prevAsiaH = na, prevAsiaL = na
var float prevLonH  = na, prevLonL  = na

if inAsia
    asiaH := na(asiaH) ? high : math.max(asiaH, high)
    asiaL := na(asiaL) ? low  : math.min(asiaL, low)
if asiaEnd
    prevAsiaH := asiaH
    prevAsiaL := asiaL
    asiaH := na
    asiaL := na

if inLon
    lonH := na(lonH) ? high : math.max(lonH, high)
    lonL := na(lonL) ? low  : math.min(lonL, low)
if lonEnd
    prevLonH := lonH
    prevLonL := lonL
    lonH := na
    lonL := na

// ══ 3. Swing High / Low ═══════════════════════
var float lastSwH = na
var float lastSwL = na
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow (low,  swingLen, swingLen)
if not na(ph) lastSwH := ph
if not na(pl) lastSwL := pl

// ══ Sweep Detection ═══════════════════════════
wickUp   = high  - math.max(open, close)
wickDown = math.min(open, close) - low

sweptUp(lvl) =>
    not na(lvl) and high > lvl and close < lvl and close < open
    and wickUp >= atr * minWick

sweptDn(lvl) =>
    not na(lvl) and low < lvl and close > lvl and close > open
    and wickDown >= atr * minWick

// ══ Score كل إشارة (1-4 نقاط) ════════════════
var int lastL = -999
var int lastS = -999

shortPts = 0
longPts  = 0

// PDH/PDL → 2 نقطة
if sweptUp(pdh)      and rsi >= rsiOB shortPts += 2
if sweptDn(pdl)      and rsi <= rsiOS longPts  += 2

// Session High/Low → 1.5 نقطة (نستخدم 2)
if sweptUp(prevAsiaH) and rsi >= rsiOB shortPts += 2
if sweptDn(prevAsiaL) and rsi <= rsiOS longPts  += 2
if sweptUp(prevLonH)  and rsi >= rsiOB shortPts += 1
if sweptDn(prevLonL)  and rsi <= rsiOS longPts  += 1

// Swing H/L → 1 نقطة
if sweptUp(lastSwH)  and rsi >= rsiOB shortPts += 1
if sweptDn(lastSwL)  and rsi <= rsiOS longPts  += 1

lSig = longPts  > 0 and (bar_index - lastL) >= cooldown
sSig = shortPts > 0 and (bar_index - lastS) >= cooldown

if lSig lastL := bar_index
if sSig lastS := bar_index

// ══ جودة الإشارة ══════════════════════════════
lStars = longPts  >= 3 ? "⭐⭐⭐" : longPts  >= 2 ? "⭐⭐" : "⭐"
sStars = shortPts >= 3 ? "⭐⭐⭐" : shortPts >= 2 ? "⭐⭐" : "⭐"

lLabel = lSig ? (longPts  >= 3 ? "▲ LONG ⭐⭐⭐" : longPts  >= 2 ? "▲ LONG ⭐⭐" : "▲ LONG ⭐") : na
sLabel = sSig ? (shortPts >= 3 ? "▼ SHORT ⭐⭐⭐" : shortPts >= 2 ? "▼ SHORT ⭐⭐" : "▼ SHORT ⭐") : na

// لون حسب الجودة
lColor = longPts  >= 3 ? color.new(#00c853,0) : longPts  >= 2 ? color.new(#66bb6a,0) : color.new(#a5d6a7,0)
sColor = shortPts >= 3 ? color.new(#d50000,0) : shortPts >= 2 ? color.new(#ef5350,0) : color.new(#ef9a9a,0)

// ══ SL & TP ═══════════════════════════════════
slL  = lSig ? low  - atr * 0.15 : na
slS  = sSig ? high + atr * 0.15 : na
tp1L = lSig ? close + (close - slL)  * 2 : na
tp1S = sSig ? close - (slS  - close) * 2 : na

// ══ Plot ══════════════════════════════════════
// المستويات
plot(pdh,       "PDH",       color.new(color.red,    40), 1, plot.style_stepline)
plot(pdl,       "PDL",       color.new(color.green,  40), 1, plot.style_stepline)
plot(prevAsiaH, "Asia High", color.new(color.orange, 50), 1, plot.style_stepline)
plot(prevAsiaL, "Asia Low",  color.new(color.blue,   50), 1, plot.style_stepline)
plot(prevLonH,  "Lon High",  color.new(color.purple, 60), 1, plot.style_circles)
plot(prevLonL,  "Lon Low",   color.new(color.teal,   60), 1, plot.style_circles)
plot(lastSwH,   "Swing H",   color.new(color.red,    70), 1, plot.style_cross)
plot(lastSwL,   "Swing L",   color.new(color.green,  70), 1, plot.style_cross)

// الإشارات
plotshape(lSig, style=shape.labelup,   location=location.belowbar,
          color=lColor, text=lLabel, textcolor=color.white, size=size.normal)
plotshape(sSig, style=shape.labeldown, location=location.abovebar,
          color=sColor, text=sLabel, textcolor=color.white, size=size.normal)

// SL / TP
plot(slL,  "SL Long",   color.new(color.red,   20), 1, plot.style_linebr)
plot(tp1L, "TP1 Long",  color.new(color.green, 20), 1, plot.style_linebr)
plot(slS,  "SL Short",  color.new(color.red,   20), 1, plot.style_linebr)
plot(tp1S, "TP1 Short", color.new(color.green, 20), 1, plot.style_linebr)

// خلفية الجلسة
bgcolor(inAsia ? color.new(color.blue,   97) :
        inLon  ? color.new(color.orange, 97) :
        inNY   ? color.new(color.green,  97) : na, title="Session")

// ══ Info Table ════════════════════════════════
var table t = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black,60), border_width=1)
if barstate.islast
    table.cell(t,0,0,"Session", text_color=color.white, text_size=size.small)
    table.cell(t,1,0, inAsia ? "🌏 Asia" : inLon ? "🇬🇧 London" : inNY ? "🗽 NY" : "—",
               text_color=color.yellow, text_size=size.small)
    table.cell(t,0,1,"PDH",     text_color=color.white,  text_size=size.small)
    table.cell(t,1,1, str.tostring(math.round(pdh,2)), text_color=color.red, text_size=size.small)
    table.cell(t,0,2,"PDL",     text_color=color.white,  text_size=size.small)
    table.cell(t,1,2, str.tostring(math.round(pdl,2)), text_color=color.green, text_size=size.small)
    table.cell(t,0,3,"RSI",     text_color=color.white,  text_size=size.small)
    table.cell(t,1,3, str.tostring(math.round(rsi,1)),
               text_color= rsi>=rsiOB ? color.red : rsi<=rsiOS ? color.lime : color.gray, text_size=size.small)
    table.cell(t,0,4,"Short Pts", text_color=color.white, text_size=size.small)
    table.cell(t,1,4, str.tostring(shortPts), text_color=shortPts>0?color.red:color.gray, text_size=size.small)
    table.cell(t,0,5,"Long Pts",  text_color=color.white, text_size=size.small)
    table.cell(t,1,5, str.tostring(longPts),  text_color=longPts>0?color.lime:color.gray, text_size=size.small)

// ══ Alerts ════════════════════════════════════
alertcondition(lSig and longPts  >= 3, "LONG ⭐⭐⭐",  "LONG_3")
alertcondition(lSig and longPts  == 2, "LONG ⭐⭐",    "LONG_2")
alertcondition(lSig and longPts  == 1, "LONG ⭐",      "LONG_1")
alertcondition(sSig and shortPts >= 3, "SHORT ⭐⭐⭐", "SHORT_3")
alertcondition(sSig and shortPts == 2, "SHORT ⭐⭐",   "SHORT_2")
alertcondition(sSig and shortPts == 1, "SHORT ⭐",     "SHORT_1")
alertcondition(lSig or sSig, "Any Signal", "SIGNAL")
