//@version=5
indicator("Kill Zone Sweep — دقة عالية", overlay=true, max_bars_back=1000)

// ══ الإعدادات ══════════════════════════════════
rsiOB    = input.int(58,   "RSI Short (أدنى)",  minval=52, maxval=80)
rsiOS    = input.int(42,   "RSI Long  (أعلى)",  minval=20, maxval=48)
minWick  = input.float(0.25,"Min Wick / ATR",    step=0.05)
swingLen = input.int(8,    "Swing Lookback",     minval=3,  maxval=20)
coolBars = input.int(20,   "Cooldown (bars)",    minval=6)
showKZ   = input.bool(true, "إظهار Kill Zones")

// ══ المؤشرات ════════════════════════════════════
atr14 = ta.atr(14)
rsi14 = ta.rsi(close, 14)

// ══ PDH / PDL ════════════════════════════════════
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_off)

// ══ Kill Zones (UTC) ════════════════════════════
// London KZ: 07:00-11:00 | NY KZ: 13:30-17:00
inLonKZ = not na(time("5", "0700-1100", "UTC"))
inNYKZ  = not na(time("5", "1330-1700", "UTC"))
inKZ    = inLonKZ or inNYKZ

// ══ Asia Range ════════════════════════════════════
inAsia  = not na(time("5", "0000-0700", "UTC"))
asiaEnd = not inAsia and inAsia[1]

var float asiaH     = na
var float asiaL     = na
var float prevAsiaH = na
var float prevAsiaL = na

if inAsia
    asiaH := na(asiaH) ? high : math.max(asiaH, high)
    asiaL := na(asiaL) ? low  : math.min(asiaL, low)
if asiaEnd
    prevAsiaH := asiaH
    prevAsiaL := asiaL
    asiaH     := na
    asiaL     := na

// ══ Swing H/L ════════════════════════════════════
var float lastSwH = na
var float lastSwL = na
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow (low,  swingLen, swingLen)
if not na(ph)
    lastSwH := ph
if not na(pl)
    lastSwL := pl

// ══ ذيول الشمعة ══════════════════════════════════
wickUp = high - math.max(open, close)
wickDn = math.min(open, close) - low

// ══ دوال السويب ══════════════════════════════════
sweptUp(lvl) =>
    not na(lvl)
    and high > lvl
    and close < lvl
    and close < open
    and wickUp >= atr14 * minWick
    and rsi14  >= rsiOB

sweptDn(lvl) =>
    not na(lvl)
    and low < lvl
    and close > lvl
    and close > open
    and wickDn >= atr14 * minWick
    and rsi14  <= rsiOS

// ══ النقاط (داخل KZ فقط) ═════════════════════════
shortPts = 0
longPts  = 0

if inKZ
    // PDH/PDL: 3 نقاط (الأقوى)
    if sweptUp(pdh)       shortPts += 3
    if sweptDn(pdl)       longPts  += 3
    // Asia H/L (London KZ فقط): 2 نقطة
    if inLonKZ and sweptUp(prevAsiaH)  shortPts += 2
    if inLonKZ and sweptDn(prevAsiaL)  longPts  += 2
    // Swing H/L: 1 نقطة
    if sweptUp(lastSwH)   shortPts += 1
    if sweptDn(lastSwL)   longPts  += 1

// ══ Cooldown ════════════════════════════════════
var int lastL = -999
var int lastS = -999

lSig = longPts  > 0 and (bar_index - lastL) >= coolBars
sSig = shortPts > 0 and (bar_index - lastS) >= coolBars

if lSig
    lastL := bar_index
if sSig
    lastS := bar_index

// ══ ألوان ونجوم ══════════════════════════════════
lLabel = longPts  >= 5 ? "▲ LONG ⭐⭐⭐" : longPts  >= 3 ? "▲ LONG ⭐⭐" : "▲ LONG ⭐"
sLabel = shortPts >= 5 ? "▼ SHORT ⭐⭐⭐" : shortPts >= 3 ? "▼ SHORT ⭐⭐" : "▼ SHORT ⭐"

lColor = longPts  >= 5 ? color.new(#00c853, 0) :
         longPts  >= 3 ? color.new(#43a047, 0) : color.new(#81c784, 0)
sColor = shortPts >= 5 ? color.new(#d50000, 0) :
         shortPts >= 3 ? color.new(#e53935, 0) : color.new(#ef9a9a, 0)

// ══ SL & TP ══════════════════════════════════════
slL  = lSig ? low  - atr14 * 0.1 : na
slS  = sSig ? high + atr14 * 0.1 : na
tp1L = lSig ? close + (close - slL) * 2 : na
tp1S = sSig ? close - (slS - close) * 2 : na

// ══ الرسم ════════════════════════════════════════
plot(pdh,       "PDH",       color.new(color.red,    35), 1, plot.style_stepline)
plot(pdl,       "PDL",       color.new(color.green,  35), 1, plot.style_stepline)
plot(prevAsiaH, "Asia High", color.new(color.orange, 40), 1, plot.style_stepline)
plot(prevAsiaL, "Asia Low",  color.new(color.blue,   40), 1, plot.style_stepline)
plot(lastSwH,   "Swing H",   color.new(color.red,    65), 1, plot.style_cross)
plot(lastSwL,   "Swing L",   color.new(color.green,  65), 1, plot.style_cross)

// Kill Zone خلفية
bgcolor(showKZ and inLonKZ ? color.new(color.orange, 90) :
        showKZ and inNYKZ  ? color.new(color.teal,   90) : na, title="Kill Zone")

// الإشارات
plotshape(lSig, style=shape.labelup,   location=location.belowbar,
          color=lColor, text=lLabel, textcolor=color.white, size=size.large)
plotshape(sSig, style=shape.labeldown, location=location.abovebar,
          color=sColor, text=sLabel, textcolor=color.white, size=size.large)

// SL / TP خطوط
plot(slL,  "SL Long",  color.new(color.red,   10), 1, plot.style_linebr)
plot(tp1L, "TP Long",  color.new(color.green, 10), 1, plot.style_linebr)
plot(slS,  "SL Short", color.new(color.red,   10), 1, plot.style_linebr)
plot(tp1S, "TP Short", color.new(color.green, 10), 1, plot.style_linebr)

// ══ جدول ════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black,55), border_width=1)
if barstate.islast
    table.cell(tbl,0,0,"Zone",     text_color=color.white,  text_size=size.small)
    table.cell(tbl,1,0, inLonKZ ? "🇬🇧 London KZ" : inNYKZ ? "🗽 NY KZ" : "— خارج KZ",
               text_color=color.yellow, text_size=size.small)
    table.cell(tbl,0,1,"PDH",      text_color=color.white, text_size=size.small)
    table.cell(tbl,1,1, str.tostring(math.round(pdh,2)),    text_color=color.red,    text_size=size.small)
    table.cell(tbl,0,2,"PDL",      text_color=color.white, text_size=size.small)
    table.cell(tbl,1,2, str.tostring(math.round(pdl,2)),    text_color=color.lime,   text_size=size.small)
    table.cell(tbl,0,3,"Asia H",   text_color=color.white, text_size=size.small)
    table.cell(tbl,1,3, str.tostring(math.round(na(prevAsiaH)?0:prevAsiaH,2)), text_color=color.orange, text_size=size.small)
    table.cell(tbl,0,4,"Asia L",   text_color=color.white, text_size=size.small)
    table.cell(tbl,1,4, str.tostring(math.round(na(prevAsiaL)?0:prevAsiaL,2)), text_color=color.blue,   text_size=size.small)
    table.cell(tbl,0,5,"RSI",      text_color=color.white, text_size=size.small)
    table.cell(tbl,1,5, str.tostring(math.round(rsi14,1)),
               text_color= rsi14>=rsiOB ? color.red : rsi14<=rsiOS ? color.lime : color.gray, text_size=size.small)
    table.cell(tbl,0,6,"Short/Long Pts", text_color=color.white, text_size=size.small)
    table.cell(tbl,1,6, str.tostring(shortPts) + " / " + str.tostring(longPts),
               text_color=color.yellow, text_size=size.small)

// ══ التنبيهات ════════════════════════════════════
alertcondition(lSig and longPts  >= 5, "LONG ⭐⭐⭐",  "LONG_HQ")
alertcondition(lSig and longPts  >= 3 and longPts  < 5, "LONG ⭐⭐", "LONG_MQ")
alertcondition(lSig and longPts  == 1, "LONG ⭐",      "LONG_LQ")
alertcondition(sSig and shortPts >= 5, "SHORT ⭐⭐⭐", "SHORT_HQ")
alertcondition(sSig and shortPts >= 3 and shortPts < 5, "SHORT ⭐⭐", "SHORT_MQ")
alertcondition(sSig and shortPts == 1, "SHORT ⭐",     "SHORT_LQ")
alertcondition(lSig or sSig, "Any KZ Signal", "SIGNAL")
