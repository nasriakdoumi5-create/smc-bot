//@version=5
indicator("Kill Zone Sweep Pro — by Nasri", overlay=true, max_bars_back=1000)

rsiOB    = input.int(58,    "RSI Short")
rsiOS    = input.int(42,    "RSI Long")
minWick  = input.float(0.25,"Min Wick/ATR", step=0.05)
swingLen = input.int(8,     "Swing Length")
coolBars = input.int(20,    "Cooldown bars")
showKZ   = input.bool(true, "Show Kill Zones")
symName  = input.string("MNQ", "Symbol Name (for webhook)")

atr14 = ta.atr(14)
rsi14 = ta.rsi(close, 14)

pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_off)

inLonKZ = not na(time("5", "0700-1100", "UTC"))
inNYKZ  = not na(time("5", "1330-1700", "UTC"))
inKZ    = inLonKZ or inNYKZ

inAsia  = not na(time("5", "0000-0700", "UTC"))
asiaEnd = not inAsia and inAsia[1]
var float prevAsiaH = na
var float prevAsiaL = na
var float tmpAsiaH  = na
var float tmpAsiaL  = na
if inAsia
    tmpAsiaH := na(tmpAsiaH) ? high : math.max(tmpAsiaH, high)
    tmpAsiaL := na(tmpAsiaL) ? low  : math.min(tmpAsiaL, low)
if asiaEnd
    prevAsiaH := tmpAsiaH
    prevAsiaL := tmpAsiaL
    tmpAsiaH  := na
    tmpAsiaL  := na

var float lastSwH = na
var float lastSwL = na
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow(low,  swingLen, swingLen)
if not na(ph)
    lastSwH := ph
if not na(pl)
    lastSwL := pl

wUp = high - math.max(open, close)
wDn = math.min(open, close) - low

cond_pdh  = inKZ    and not na(pdh)       and high > pdh       and close < pdh       and close < open and wUp >= atr14 * minWick and rsi14 >= rsiOB
cond_pdl  = inKZ    and not na(pdl)       and low  < pdl       and close > pdl       and close > open and wDn >= atr14 * minWick and rsi14 <= rsiOS
cond_asiH = inLonKZ and not na(prevAsiaH) and high > prevAsiaH and close < prevAsiaH and close < open and wUp >= atr14 * minWick and rsi14 >= rsiOB
cond_asiL = inLonKZ and not na(prevAsiaL) and low  < prevAsiaL and close > prevAsiaL and close > open and wDn >= atr14 * minWick and rsi14 <= rsiOS
cond_swH  = inKZ    and not na(lastSwH)   and high > lastSwH   and close < lastSwH   and close < open and wUp >= atr14 * minWick and rsi14 >= rsiOB
cond_swL  = inKZ    and not na(lastSwL)   and low  < lastSwL   and close > lastSwL   and close > open and wDn >= atr14 * minWick and rsi14 <= rsiOS

pts_short = (cond_pdh ? 3 : 0) + (cond_asiH ? 2 : 0) + (cond_swH ? 1 : 0)
pts_long  = (cond_pdl ? 3 : 0) + (cond_asiL ? 2 : 0) + (cond_swL ? 1 : 0)

var int lastL = -999
var int lastS = -999

sig_long  = pts_long  > 0 and (bar_index - lastL) >= coolBars
sig_short = pts_short > 0 and (bar_index - lastS) >= coolBars

if sig_long
    lastL := bar_index
if sig_short
    lastS := bar_index

sl_long_v   = low  - atr14 * 0.1
sl_short_v  = high + atr14 * 0.1
tp_long_v   = close + (close - sl_long_v)  * 2
tp_short_v  = close - (sl_short_v - close) * 2
tp2_long_v  = close + (close - sl_long_v)  * 3
tp2_short_v = close - (sl_short_v - close) * 3

sl_long  = sig_long  ? sl_long_v  : na
sl_short = sig_short ? sl_short_v : na
tp_long  = sig_long  ? tp_long_v  : na
tp_short = sig_short ? tp_short_v : na

plot(pdh,       "PDH",    color.new(color.red,    35), 1, plot.style_stepline)
plot(pdl,       "PDL",    color.new(color.green,  35), 1, plot.style_stepline)
plot(prevAsiaH, "Asia H", color.new(color.orange, 40), 1, plot.style_stepline)
plot(prevAsiaL, "Asia L", color.new(color.blue,   40), 1, plot.style_stepline)

bgcolor(showKZ and inLonKZ ? color.new(color.orange, 90) : showKZ and inNYKZ ? color.new(color.teal, 90) : na, title="KZ")

plotshape(sig_long  and pts_long  >= 5,                   style=shape.labelup,   location=location.belowbar, color=color.new(#00c853,0), text="▲ LONG ★★★", textcolor=color.white, size=size.large)
plotshape(sig_long  and pts_long  >= 3 and pts_long  < 5, style=shape.labelup,   location=location.belowbar, color=color.new(#43a047,0), text="▲ LONG ★★",  textcolor=color.white, size=size.large)
plotshape(sig_long  and pts_long  < 3,                    style=shape.labelup,   location=location.belowbar, color=color.new(#81c784,0), text="▲ LONG ★",   textcolor=color.white, size=size.large)
plotshape(sig_short and pts_short >= 5,                   style=shape.labeldown, location=location.abovebar, color=color.new(#d50000,0), text="▼ SHORT ★★★",textcolor=color.white, size=size.large)
plotshape(sig_short and pts_short >= 3 and pts_short < 5, style=shape.labeldown, location=location.abovebar, color=color.new(#e53935,0), text="▼ SHORT ★★", textcolor=color.white, size=size.large)
plotshape(sig_short and pts_short < 3,                    style=shape.labeldown, location=location.abovebar, color=color.new(#ef9a9a,0), text="▼ SHORT ★",  textcolor=color.white, size=size.large)

plot(sl_long,  "SL L", color.new(color.red,   10), 1, plot.style_linebr)
plot(tp_long,  "TP L", color.new(color.green, 10), 1, plot.style_linebr)
plot(sl_short, "SL S", color.new(color.red,   10), 1, plot.style_linebr)
plot(tp_short, "TP S", color.new(color.green, 10), 1, plot.style_linebr)

// ── Webhook JSON Alerts ───────────────────────────
kzName = inLonKZ ? "London KZ" : "NY KZ"
starsL = pts_long  >= 5 ? "3" : pts_long  >= 3 ? "2" : "1"
starsS = pts_short >= 5 ? "3" : pts_short >= 3 ? "2" : "1"

if sig_long
    alert('{"s":"' + symName + '","t":"LONG","p":' + str.tostring(math.round(close,2))
         + ',"sl":'  + str.tostring(math.round(sl_long_v,2))
         + ',"tp1":' + str.tostring(math.round(tp_long_v,2))
         + ',"tp2":' + str.tostring(math.round(tp2_long_v,2))
         + ',"r":'   + str.tostring(math.round(rsi14,1))
         + ',"a":'   + str.tostring(math.round(atr14,2))
         + ',"pts":' + str.tostring(pts_long)
         + ',"q":'   + starsL
         + ',"src":"kz_' + kzName + '"}',
         alert.freq_once_per_bar_close)

if sig_short
    alert('{"s":"' + symName + '","t":"SHORT","p":' + str.tostring(math.round(close,2))
         + ',"sl":'  + str.tostring(math.round(sl_short_v,2))
         + ',"tp1":' + str.tostring(math.round(tp_short_v,2))
         + ',"tp2":' + str.tostring(math.round(tp2_short_v,2))
         + ',"r":'   + str.tostring(math.round(rsi14,1))
         + ',"a":'   + str.tostring(math.round(atr14,2))
         + ',"pts":' + str.tostring(pts_short)
         + ',"q":'   + starsS
         + ',"src":"kz_' + kzName + '"}',
         alert.freq_once_per_bar_close)
