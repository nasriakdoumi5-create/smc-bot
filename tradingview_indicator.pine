//@version=5
indicator("EMA21 Bounce — 3TF", overlay=true, max_bars_back=500)

cooldown = input.int(12, "Cooldown bars", minval=6)
rsiMinL  = input.int(42, "RSI Min (Long)")
rsiMaxS  = input.int(58, "RSI Max (Short)")

// ── 1H Bias ───────────────────────────────────
ema50h  = request.security(syminfo.tickerid, "60", ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
ema200h = request.security(syminfo.tickerid, "60", ta.ema(close, 200), lookahead=barmerge.lookahead_off)
bull1h  = ema50h > ema200h
bear1h  = ema50h < ema200h

// ── 5M ────────────────────────────────────────
e21 = ta.ema(close, 21)
rsi = ta.rsi(close, 14)
atr = ta.atr(14)

// ── الشرط الأساسي: السعر كان فوق EMA21 ثم جاء إليه ──
// 5 من 6 شمعات سابقة كانت فوق EMA21 = pullback حقيقي
aboveC6 = (close[1] > e21[1] ? 1 : 0) + (close[2] > e21[2] ? 1 : 0) +
          (close[3] > e21[3] ? 1 : 0) + (close[4] > e21[4] ? 1 : 0) +
          (close[5] > e21[5] ? 1 : 0) + (close[6] > e21[6] ? 1 : 0)

belowC6 = (close[1] < e21[1] ? 1 : 0) + (close[2] < e21[2] ? 1 : 0) +
          (close[3] < e21[3] ? 1 : 0) + (close[4] < e21[4] ? 1 : 0) +
          (close[5] < e21[5] ? 1 : 0) + (close[6] < e21[6] ? 1 : 0)

cRange = high - low + 0.001

// ── LONG: pullback للـ EMA21 + ارتداد صاعد واضح ──
bUp = aboveC6 >= 5          // كان فوق EMA21
    and low  <= e21          // الذيل لمس EMA21
    and close > e21          // أغلق فوق EMA21
    and close > open         // شمعة صاعدة
    and (close - open) / cRange > 0.35   // جسم لا يقل عن 35% (ليس دوجي)
    and rsi >= rsiMinL and rsi < 68

// ── SHORT: pullback للـ EMA21 + ارتداد هابط واضح ──
bDn = belowC6 >= 5
    and high >= e21
    and close < e21
    and close < open
    and (open - close) / cRange > 0.35
    and rsi <= rsiMaxS and rsi > 32

// ── Cooldown ──────────────────────────────────
var int lL = -100
var int lS = -100

lSig = bull1h and bUp and (bar_index - lL) >= cooldown
sSig = bear1h and bDn and (bar_index - lS) >= cooldown

if lSig
    lL := bar_index
if sSig
    lS := bar_index

// ── SL & TP ───────────────────────────────────
slL  = ta.lowest(low,  4) - atr * 0.15
slS  = ta.highest(high,4) + atr * 0.15
rL   = close - slL
rS   = slS - close
tp1L = close + rL * 2
tp1S = close - rS * 2

// ── Plot ──────────────────────────────────────
plot(e21, "EMA21", color.blue, 2)

plotshape(lSig, style=shape.labelup,   location=location.belowbar,
          color=color.green, text="▲ LONG",  textcolor=color.white, size=size.normal)
plotshape(sSig, style=shape.labeldown, location=location.abovebar,
          color=color.red,   text="▼ SHORT", textcolor=color.white, size=size.normal)

// SL و TP خطوط
plot(lSig ? slL  : na, color=color.new(color.red,  20), linewidth=1, style=plot.style_linebr)
plot(lSig ? tp1L : na, color=color.new(color.green,20), linewidth=1, style=plot.style_linebr)
plot(sSig ? slS  : na, color=color.new(color.red,  20), linewidth=1, style=plot.style_linebr)
plot(sSig ? tp1S : na, color=color.new(color.green,20), linewidth=1, style=plot.style_linebr)

bgcolor(bull1h ? color.new(color.green, 96) : bear1h ? color.new(color.red, 96) : na)

// ── Alert ─────────────────────────────────────
alertcondition(lSig, "LONG",  "LONG")
alertcondition(sSig, "SHORT", "SHORT")
