//@version=5
indicator("EMA21 Bounce — 3TF Signal", overlay=true, max_bars_back=500)

// ══ إعدادات ══════════════════════════════════════
cooldownBars = input.int(6,   "Cooldown (عدد الشمعات بين إشارتين)", minval=1)
rsiLow       = input.int(35,  "RSI Min", minval=10, maxval=50)
rsiHigh      = input.int(65,  "RSI Max", minval=50, maxval=80)

// ══ بيانات HTF — 1H Bias ═══════════════════════
ema50_1h  = request.security(syminfo.tickerid, "60", ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
ema200_1h = request.security(syminfo.tickerid, "60", ta.ema(close, 200), lookahead=barmerge.lookahead_off)
htfBull   = ema50_1h > ema200_1h
htfBear   = ema50_1h < ema200_1h

// ══ بيانات MTF — 15M Structure ══════════════════
ema21_15m = request.security(syminfo.tickerid, "15", ta.ema(close, 21), lookahead=barmerge.lookahead_off)
close_15m = request.security(syminfo.tickerid, "15", close,             lookahead=barmerge.lookahead_off)
atr_15m   = request.security(syminfo.tickerid, "15", ta.atr(14),        lookahead=barmerge.lookahead_off)

// السعر قريب من EMA21 على 15M
mtfNear = math.abs(close_15m - ema21_15m) <= atr_15m * 0.6

// ══ مؤشرات الـ 5M ════════════════════════════════
ema21 = ta.ema(close, 21)
rsi   = ta.rsi(close, 14)
atr   = ta.atr(14)

// ══ شروط الارتداد الصارمة ════════════════════════
// LONG: الشمعة الحالية تلمس EMA21 وتغلق فوقه بجسم واضح
bodyBull  = (close - open) >= atr * 0.15          // جسم الشمعة ذو حجم كافٍ
wickBull  = low < ema21                            // الذيل السفلي اخترق EMA21
closeBull = close > ema21 and close > open         // إغلاق فوق EMA21 وصاعد
prevBull  = close[1] <= ema21[1] * 1.002          // الشمعة السابقة كانت قرب/تحت EMA21

bouncedUp = wickBull and closeBull and bodyBull and prevBull

// SHORT: العكس
bodySell  = (open - close) >= atr * 0.15
wickSell  = high > ema21
closeSell = close < ema21 and close < open
prevSell  = close[1] >= ema21[1] * 0.998

bouncedDown = wickSell and closeSell and bodySell and prevSell

// RSI
rsiOkLong  = rsi >= rsiLow and rsi <= rsiHigh
rsiOkShort = rsi >= rsiLow and rsi <= rsiHigh

// ══ Cooldown — يمنع تكرار الإشارات ══════════════
var int lastLong  = -100
var int lastShort = -100

longReady  = (bar_index - lastLong)  >= cooldownBars
shortReady = (bar_index - lastShort) >= cooldownBars

// ══ الإشارة النهائية (كل الشروط) ════════════════
longSig  = htfBull and mtfNear and bouncedUp   and rsiOkLong  and longReady
shortSig = htfBear and mtfNear and bouncedDown and rsiOkShort and shortReady

if longSig
    lastLong := bar_index
if shortSig
    lastShort := bar_index

// ══ SL و TP ═══════════════════════════════════
slLong   = ta.lowest(low, 4) - atr * 0.2
slShort  = ta.highest(high, 4) + atr * 0.2
rL       = close - slLong
rS       = slShort - close
tp1Long  = close + rL * 2.0
tp1Short = close - rS * 2.0
tp2Long  = close + rL * 3.0
tp2Short = close - rS * 3.0

// ══ رسم ══════════════════════════════════════════
plot(ema21,     "EMA21 (5M)", color.blue, 2)
plot(ema21_15m, "EMA21 (15M)", color.new(color.purple, 40), 1, plot.style_stepline)

// إشارات
plotshape(longSig,  style=shape.labelup,   location=location.belowbar,
          color=color.new(color.green, 0), text="▲ LONG",  textcolor=color.white, size=size.normal)
plotshape(shortSig, style=shape.labeldown, location=location.abovebar,
          color=color.new(color.red, 0),   text="▼ SHORT", textcolor=color.white, size=size.normal)

// خطوط SL و TP عند الإشارة
plotshape(longSig,  style=shape.triangleup, location=location.absolute, color=color.new(color.green, 80), size=size.tiny)

// خلفية الاتجاه HTF
bgcolor(htfBull ? color.new(color.green, 97) : htfBear ? color.new(color.red, 97) : na)

// ══ جدول المعلومات ════════════════════════════════
var table info = table.new(position.top_right, 2, 5,
  bgcolor=color.new(color.black, 60), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(info, 0, 0, "1H Bias",   text_color=color.white,  text_size=size.small)
    table.cell(info, 1, 0, htfBull ? "▲ BULL" : "▼ BEAR",
               text_color=htfBull ? color.lime : color.red, text_size=size.small)
    table.cell(info, 0, 1, "15M Near",  text_color=color.white,  text_size=size.small)
    table.cell(info, 1, 1, mtfNear ? "✓ نعم" : "✗ لا",
               text_color=mtfNear ? color.lime : color.red, text_size=size.small)
    table.cell(info, 0, 2, "RSI",       text_color=color.white,  text_size=size.small)
    table.cell(info, 1, 2, str.tostring(math.round(rsi, 1)),
               text_color=(rsiOkLong or rsiOkShort) ? color.lime : color.orange, text_size=size.small)
    table.cell(info, 0, 3, "ATR",       text_color=color.white,  text_size=size.small)
    table.cell(info, 1, 3, str.tostring(math.round(atr, 1)), text_color=color.white, text_size=size.small)
    table.cell(info, 0, 4, "Cooldown",  text_color=color.white,  text_size=size.small)
    table.cell(info, 1, 4, str.tostring(cooldownBars) + " bars",
               text_color=color.gray, text_size=size.small)

// ══ Alerts ════════════════════════════════════════
alertcondition(longSig,  "LONG Signal",  "LONG")
alertcondition(shortSig, "SHORT Signal", "SHORT")
