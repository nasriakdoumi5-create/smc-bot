//@version=5
// ═══════════════════════════════════════════════════════
//   IFA Data Feed V2 — Raw Market Data Only
//   ─────────────────────────────────────────────────────
//   TradingView = مزوّد بيانات خام فقط.
//   لا FVG، لا BOS، لا CHOCH، لا Order Blocks، لا إشارات.
//   كل التحليل يتم داخل محرك IFA-OS.
//
//   الإعداد:
//   ضع هذا المؤشر على شارت كل إطار زمني لكل رمز:
//     MNQ: 5M, 15M, 1H, 4H, D   (5 تنبيهات)
//     MGC: 5M, 15M, 1H, 4H, D   (5 تنبيهات)
//     MCL: 5M, 15M, 1H, 4H, D   (5 تنبيهات)
//   لكل شارت أنشئ Alert واحداً:
//     Condition : IFA Data Feed V2 → Any alert() function call
//     Expiration: Open-ended
//     Webhook   : https://<your-app>/webhook
//   يرسل كل شمعة مؤكدة عند إغلاقها. لا شيء آخر.
// ═══════════════════════════════════════════════════════
indicator("IFA Data Feed V2 — Raw Candle", overlay=true)

symName = input.string("MNQ", "Symbol (MNQ / MGC / MCL)")

// جلسة الشمعة حسب توقيت افتتاحها (UTC)
f_session() =>
    int m = hour(time, "UTC") * 60 + minute(time, "UTC")
    m < 7 * 60 ? "Asia" : m < 13 * 60 ? "London" : m < 22 * 60 ? "NewYork" : "Off"

if barstate.isconfirmed
    string msg = '{"src":"ifa_candle"'
         + ',"symbol":"'    + symName + '"'
         + ',"exchange":"'  + syminfo.prefix + '"'
         + ',"timeframe":"' + timeframe.period + '"'
         + ',"timestamp":'  + str.tostring(time)
         + ',"open":'       + str.tostring(open,  "#.####")
         + ',"high":'       + str.tostring(high,  "#.####")
         + ',"low":'        + str.tostring(low,   "#.####")
         + ',"close":'      + str.tostring(close, "#.####")
         + ',"volume":'     + str.tostring(nz(volume, 0), "#")
         + ',"session":"'   + f_session() + '"'
         + ',"bar_index":'  + str.tostring(bar_index)
         + '}'
    alert(msg, alert.freq_once_per_bar_close)

plot(close, title="Close", display=display.none)
