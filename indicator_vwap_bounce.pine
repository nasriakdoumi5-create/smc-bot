//@version=5
indicator("VWAP Bounce — NQ Precision", overlay=true, max_bars_back=500)

// ── إعدادات ─────────────────────────────────────
bandMult = input.float(1.5, "Band Multiplier (ATR)", step=0.25)
rsiOB    = input.int(58,    "RSI Short threshold")
rsiOS    = input.int(42,    "RSI Long  threshold")
emaLen   = input.int(50,    "EMA Trend Filter")
cooldown = input.int(10,    "Cooldown bars")
showBand = input.bool(true, "Show Bands")

// ── مؤشرات ──────────────────────────────────────
vwap_val = ta.vwap(hlc3)
atr14    = ta.atr(14)
rsi14    = ta.rsi(close, 14)
ema50    = ta.ema(close, emaLen)

// ── نطاقات ──────────────────────────────────────
upperBand = vwap_val + atr14 * bandMult
lowerBand = vwap_val - atr14 * bandMult

// ── Session (London + NY) UTC ────────────────────
inSession = not na(time("5", "0700-2000", "UTC"))

// ── ذيول الشمعة ──────────────────────────────────
wUp = high - math.max(open, close)
wDn = math.min(open, close) - low

// ── شروط الإشارة ─────────────────────────────────
// SHORT: لمس Upper Band + شمعة هابطة برفض + RSI مرتفع
cond_short = inSession
           and high >= upperBand
           and close < upperBand
           and close < open
           and wUp  >= atr14 * 0.15
           and rsi14 >= rsiOB

// LONG: لمس Lower Band + شمعة صاعدة برفض + RSI منخفض
cond_long  = inSession
           and low  <= lowerBand
           and close > lowerBand
           and close > open
           and wDn  >= atr14 * 0.15
           and rsi14 <= rsiOS

// ── Cooldown ─────────────────────────────────────
var int lastL = -999
var int lastS = -999

sig_long  = cond_long  and (bar_index - lastL) >= cooldown
sig_short = cond_short and (bar_index - lastS) >= cooldown

if sig_long
    lastL := bar_index
if sig_short
    lastS := bar_index

// ── SL / TP ───────────────────────────────────────
sl_long  = sig_long  ? low  - atr14 * 0.1 : na
sl_short = sig_short ? high + atr14 * 0.1 : na
tp_long  = sig_long  ? close + (close - sl_long)  * 2 : na
tp_short = sig_short ? close - (sl_short - close) * 2 : na

// ── رسم ──────────────────────────────────────────
plot(vwap_val,                           "VWAP",  color.new(color.yellow, 0),  2)
plot(showBand ? upperBand : na, "Upper", color.new(color.red,    25), 1, plot.style_stepline)
plot(showBand ? lowerBand : na, "Lower", color.new(color.green,  25), 1, plot.style_stepline)
plot(ema50,                     "EMA50", color.new(color.orange, 30), 1)

bgcolor(inSession ? color.new(color.blue, 97) : na, title="Session")

plotshape(sig_long,  style=shape.labelup,   location=location.belowbar, color=color.new(color.green, 0), text="▲ LONG",  textcolor=color.white, size=size.normal)
plotshape(sig_short, style=shape.labeldown, location=location.abovebar, color=color.new(color.red,   0), text="▼ SHORT", textcolor=color.white, size=size.normal)

plot(sl_long,  "SL L", color.new(color.red,   10), 1, plot.style_linebr)
plot(tp_long,  "TP L", color.new(color.green, 10), 1, plot.style_linebr)
plot(sl_short, "SL S", color.new(color.red,   10), 1, plot.style_linebr)
plot(tp_short, "TP S", color.new(color.green, 10), 1, plot.style_linebr)

// ── جدول ─────────────────────────────────────────
var table t = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 55), border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "VWAP",   text_color=color.white,  text_size=size.small)
    table.cell(t, 1, 0, str.tostring(math.round(vwap_val, 2)), text_color=color.yellow, text_size=size.small)
    table.cell(t, 0, 1, "Upper",  text_color=color.white,  text_size=size.small)
    table.cell(t, 1, 1, str.tostring(math.round(upperBand, 2)), text_color=color.red, text_size=size.small)
    table.cell(t, 0, 2, "Lower",  text_color=color.white,  text_size=size.small)
    table.cell(t, 1, 2, str.tostring(math.round(lowerBand, 2)), text_color=color.lime, text_size=size.small)
    table.cell(t, 0, 3, "RSI",    text_color=color.white,  text_size=size.small)
    table.cell(t, 1, 3, str.tostring(math.round(rsi14, 1)), text_color=rsi14 >= rsiOB ? color.red : rsi14 <= rsiOS ? color.lime : color.gray, text_size=size.small)

// ── تنبيهات ───────────────────────────────────────
alertcondition(sig_long,            "LONG — VWAP Bounce",  "LONG")
alertcondition(sig_short,           "SHORT — VWAP Bounce", "SHORT")
alertcondition(sig_long or sig_short, "Signal",            "SIGNAL")
