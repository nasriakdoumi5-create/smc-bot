//@version=5
strategy("14:00 Last Wave — Fix",
         overlay            = true,
         calc_on_every_tick = true,
         default_qty_type   = strategy.fixed,
         default_qty_value  = 1,
         initial_capital    = 10000,
         commission_type    = strategy.commission.cash_per_contract,
         commission_value   = 0.5,
         slippage           = 1)

i_lookback = input.int(11,   "Bars before 14:00 for wave", minval=3, maxval=30)
i_rr       = input.float(1.5, "RR Ratio", minval=1.0, maxval=5.0, step=0.5)

is_entry = hour(time,"UTC") == 14 and minute(time,"UTC") == 0
is_new_d = ta.change(time("D")) != 0

wave_now  = close[1]
wave_ref  = close[i_lookback + 1]
wave_size = math.abs(wave_now - wave_ref)
wave_up   = wave_now > wave_ref
wave_down = wave_now < wave_ref

var int day_trades = 0
if is_new_d
    day_trades := 0
can_trade = day_trades < 1 and strategy.position_size == 0

go_short = is_entry and wave_up   and wave_size > 5 and can_trade
go_long  = is_entry and wave_down and wave_size > 5 and can_trade

var array<int>   a_entry = array.new_int()
var array<int>   a_exit  = array.new_int()
var array<float> a_ep    = array.new_float()
var array<float> a_tp    = array.new_float()
var array<float> a_sl    = array.new_float()
var array<bool>  a_short = array.new_bool()
var int          last_n  = 0
var float        ep      = na
var float        tp_p    = na
var float        sl_p    = na

if go_short
    float td = wave_size
    float sd = wave_size / i_rr
    ep   := close
    tp_p := close - td
    sl_p := close + sd
    day_trades += 1
    strategy.entry("S", strategy.short)
    strategy.exit("Sx", "S", limit=tp_p, stop=sl_p)
    array.push(a_entry, bar_index)
    array.push(a_ep,    close)
    array.push(a_tp,    close - td)
    array.push(a_sl,    close + sd)
    array.push(a_short, true)

if go_long
    float td = wave_size
    float sd = wave_size / i_rr
    ep   := close
    tp_p := close + td
    sl_p := close - sd
    day_trades += 1
    strategy.entry("L", strategy.long)
    strategy.exit("Lx", "L", limit=tp_p, stop=sl_p)
    array.push(a_entry, bar_index)
    array.push(a_ep,    close)
    array.push(a_tp,    close + td)
    array.push(a_sl,    close - sd)
    array.push(a_short, false)

if strategy.closedtrades > last_n
    array.push(a_exit, bar_index)
    last_n := strategy.closedtrades

if strategy.position_size == 0 and not (go_short or go_long)
    ep   := na
    tp_p := na
    sl_p := na

p_ep = plot(strategy.position_size != 0 ? ep   : na, "Entry", color.gray, 2, plot.style_linebr)
p_tp = plot(strategy.position_size != 0 ? tp_p : na, "TP",    color.lime, 2, plot.style_linebr)
p_sl = plot(strategy.position_size != 0 ? sl_p : na, "SL",    color.red,  2, plot.style_linebr)
fill(p_ep, p_tp, color.new(color.green, 55))
fill(p_ep, p_sl, color.new(color.red,   55))

plotshape(go_short, "SHORT", shape.triangledown, location.abovebar, color.red,  size=size.small)
plotshape(go_long,  "LONG",  shape.triangleup,   location.belowbar, color.lime, size=size.small)
bgcolor(is_entry ? color.new(color.yellow, 88) : na)

if barstate.islast
    int n_closed = strategy.closedtrades
    int n_stored = array.size(a_entry)
    int draw_n   = math.min(n_stored, n_closed)

    if draw_n > 0
        for i = 0 to draw_n - 1
            int   b_start = array.get(a_entry, i)
            int   b_end   = array.size(a_exit) > i ? array.get(a_exit, i) + 2 : b_start + 30
            float e       = array.get(a_ep,    i)
            float tp_v    = array.get(a_tp,    i)
            float sl_v    = array.get(a_sl,    i)
            bool  is_s    = array.get(a_short, i)
            bool  won     = strategy.closedtrades.profit(i) > 0

            color c_tp = won ? color.new(color.green, 30) : color.new(color.green, 75)
            color c_sl = won ? color.new(color.red,   75) : color.new(color.red,   30)
            color b_tp = won ? color.green : color.new(color.green, 40)
            color b_sl = won ? color.new(color.red, 40) : color.red

            float top_tp = is_s ? e    : tp_v
            float bot_tp = is_s ? tp_v : e
            box.new(b_start, top_tp, b_end, bot_tp, bgcolor=c_tp, border_color=b_tp, border_width=2, text=won ? "TP" : "TP", text_color=color.white, text_size=size.small, text_halign=text.align_left)

            float top_sl = is_s ? sl_v : e
            float bot_sl = is_s ? e    : sl_v
            box.new(b_start, top_sl, b_end, bot_sl, bgcolor=c_sl, border_color=b_sl, border_width=2, text="SL", text_color=color.white, text_size=size.small, text_halign=text.align_left)

var table t = na

if barstate.islast
    if na(t)
        t := table.new(position.top_right, 2, 7, frame_color=color.gray, frame_width=1, border_color=color.new(color.gray, 50), border_width=1)

    int   n      = strategy.closedtrades
    int   wins   = 0
    int   losses = 0
    if n > 0
        for i = 0 to n - 1
            if strategy.closedtrades.profit(i) > 0
                wins += 1
            else
                losses += 1

    int   total = n + (strategy.position_size != 0 ? 1 : 0)
    float wr    = n > 0 ? wins / n * 100 : 0.0
    float net   = strategy.netprofit
    float avg_l = losses > 0 ? math.abs(strategy.grossloss) / losses : 0.0

    color H = color.new(#1a237e, 0)
    color A = color.new(#0d1b2a, 20)
    color B = color.new(#1b2838, 20)

    table.cell(t, 0, 0, "Last Wave",                     bgcolor=H, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "14:00 UTC",                     bgcolor=H, text_color=color.white, text_size=size.small)
    table.cell(t, 0, 1, "الصفقات",                       bgcolor=A, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(total),              bgcolor=A, text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "ربح",                            bgcolor=B, text_color=color.lime,  text_size=size.small)
    table.cell(t, 1, 2, str.tostring(wins),               bgcolor=B, text_color=color.lime,  text_size=size.small)
    table.cell(t, 0, 3, "خسارة",                          bgcolor=A, text_color=color.red,   text_size=size.small)
    table.cell(t, 1, 3, str.tostring(losses),             bgcolor=A, text_color=color.red,   text_size=size.small)
    table.cell(t, 0, 4, "نسبة النجاح",                   bgcolor=B, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(wr, "#.#") + "%",   bgcolor=B, text_color=wr >= 50 ? color.lime : color.red, text_size=size.small)
    table.cell(t, 0, 5, "خسارة متوسط",                   bgcolor=A, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, "$" + str.tostring(avg_l, "#.#"),bgcolor=A, text_color=color.red,   text_size=size.small)
    table.cell(t, 0, 6, "Net Profit",                    bgcolor=H, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, "$" + str.tostring(net, "#.#"),  bgcolor=H, text_color=net >= 0 ? color.lime : color.red, text_size=size.small)
