//@version=5
strategy("AMD SNIPER — NQ & NG | 1 Signal/Day",
     shorttitle        = "AMD SNIPER",
     overlay           = true,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 2,
     initial_capital   = 100000,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.02,
     pyramiding        = 0)

// ══════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════
g_amd = "🌍 AMD Sessions (UTC)"
asiaStart = input.int(0,  "Asia Start UTC",  minval=0, maxval=23, group=g_amd)
asiaEnd   = input.int(7,  "Asia End UTC",    minval=0, maxval=23, group=g_amd)
kzStart   = input.int(13, "NY KZ Start UTC", minval=0, maxval=23, group=g_amd)
kzEnd     = input.int(16, "NY KZ End UTC",   minval=0, maxval=23, group=g_amd)

g_filter = "🎯 Filters"
minScore  = input.int(4,    "Min Score (max 7)", minval=3, maxval=7,  group=g_filter)
dispMult  = input.float(1.5,"Displacement × ATR",minval=0.5, step=0.1, group=g_filter)
sweepPct  = input.float(0.2,"Min Sweep % of Range", minval=0.05, step=0.05, group=g_filter)

g_risk = "💰 Risk"
atrP = input.int(14,    "ATR Period",      minval=1,   group=g_risk)
slM  = input.float(0.3, "SL Buffer × ATR", minval=0.1, step=0.1, group=g_risk)
tp1R = input.float(1.5, "TP1 R:R",         minval=1.0, step=0.25, group=g_risk)
tp2R = input.float(3.0, "TP2 R:R",         minval=1.5, step=0.25, group=g_risk)

// ══════════════════════════════════════════════
// SESSIONS (UTC)
// ══════════════════════════════════════════════
hrUTC = hour(time, "UTC")

inAsia() => hrUTC >= asiaStart and hrUTC < asiaEnd
inKZ()   => hrUTC >= kzStart   and hrUTC < kzEnd

// ══════════════════════════════════════════════
// ONE SIGNAL PER DAY
// ══════════════════════════════════════════════
var bool todayDone = false
if dayofmonth != dayofmonth[1]
    todayDone := false

// ══════════════════════════════════════════════
// ATR
// ══════════════════════════════════════════════
atrV = ta.atr(atrP)

// ══════════════════════════════════════════════
// AMD — ASIA RANGE (Accumulation)
// ══════════════════════════════════════════════
var float aH     = na
var float aL     = na
var float asiaH  = na
var float asiaL  = na
var bool  asiaOk = false

asOn  = inAsia()
wasAs = inAsia()[1]

if asOn and not wasAs
    aH     := high
    aL     := low
    asiaOk := false

if asOn
    aH := math.max(aH, high)
    aL := math.min(aL, low)

if not asOn and wasAs
    asiaH  := aH
    asiaL  := aL
    asiaOk := true

if dayofmonth != dayofmonth[1]
    asiaOk := false
    asiaH  := na
    asiaL  := na

asiaRng  = asiaOk ? asiaH - asiaL : float(na)
rangePct = asiaOk and asiaL > 0 ? asiaRng / asiaL : float(na)
rangeOK  = not na(rangePct) and rangePct >= 0.002

// ══════════════════════════════════════════════
// HTF BIAS — Previous Day Direction
// ══════════════════════════════════════════════
pdClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)
pdOpen  = request.security(syminfo.tickerid, "D", open[1],  lookahead=barmerge.lookahead_off)
htfBull = not na(pdClose) and pdClose > pdOpen
htfBear = not na(pdClose) and pdClose < pdOpen

// ══════════════════════════════════════════════
// AMD — MANIPULATION (Hunt above/below Asia Range)
// ══════════════════════════════════════════════
var bool  mUp  = false
var bool  mDn  = false
var float mHP  = na
var float mLP  = na
var bool  mUpC = false
var bool  mDnC = false

minSweep = asiaOk and not na(asiaRng) ? asiaRng * sweepPct : float(na)

if asiaOk and not asOn and not na(minSweep)
    if not mUp and high > asiaH + minSweep
        mUp  := true
        mHP  := high
        mUpC := close < asiaH
    if not mDn and low < asiaL - minSweep
        mDn  := true
        mLP  := low
        mDnC := close > asiaL
    if mUp and not mUpC and close < asiaH
        mUpC := true
    if mDn and not mDnC and close > asiaL
        mDnC := true

if dayofmonth != dayofmonth[1]
    mUp  := false
    mDn  := false
    mHP  := na
    mLP  := na
    mUpC := false
    mDnC := false

// ══════════════════════════════════════════════
// SMC — SWING HIGHS / LOWS
// ══════════════════════════════════════════════
swLen = 10
swH   = ta.pivothigh(high, swLen, swLen)
swL   = ta.pivotlow(low,  swLen, swLen)

var float lastSH = na
var float lastSL = na

if not na(swH)
    lastSH := swH
if not na(swL)
    lastSL := swL

// ══════════════════════════════════════════════
// SMC — LIQUIDITY SWEEPS
// ══════════════════════════════════════════════
bssSweep = not na(lastSH) and high > lastSH * 1.001 and close < lastSH
sssSweep = not na(lastSL) and low  < lastSL * 0.999 and close > lastSL

var bool hadBSS = false
var bool hadSSS = false
var int  bssB   = 0
var int  sssB   = 0

if bssSweep
    hadBSS := true
    bssB   := bar_index
if sssSweep
    hadSSS := true
    sssB   := bar_index
if bar_index - bssB > 40
    hadBSS := false
if bar_index - sssB > 40
    hadSSS := false

// ══════════════════════════════════════════════
// SMC — MARKET STRUCTURE (BOS / CHoCH)
// ══════════════════════════════════════════════
var int mStr = 0

bullBrk   = not na(lastSH) and close > lastSH and not (close[1] > lastSH)
bearBrk   = not na(lastSL) and close < lastSL and not (close[1] < lastSL)
bullCHoCH = mStr[1] == -1 and bullBrk
bearCHoCH = mStr[1] ==  1 and bearBrk
bullBOS   = mStr[1] ==  1 and bullBrk
bearBOS   = mStr[1] == -1 and bearBrk

if bullBrk
    mStr := 1
else if bearBrk
    mStr := -1

// ══════════════════════════════════════════════
// DISPLACEMENT (شمعة قوية بعد Hunt)
// ══════════════════════════════════════════════
body      = math.abs(close - open)
dspThres  = atrV * dispMult

var bool dspL = false
var bool dspB = false

if mDn and mDnC and close > open and body > dspThres and not dspL
    dspL := true
if mUp and mUpC and open > close and body > dspThres and not dspB
    dspB := true

if dayofmonth != dayofmonth[1]
    dspL := false
    dspB := false

// ══════════════════════════════════════════════
// FVG — Fair Value Gap
// ══════════════════════════════════════════════
bullFVG = low > high[2]
bearFVG = high < low[2]

var float bFT = na
var float bFB = na
var float sFT = na
var float sFB = na

if bullFVG
    bFT := low
    bFB := high[2]
if bearFVG
    sFT := low[2]
    sFB := high

inBFVG = not na(bFT) and close <= bFT and close >= bFB
inSFVG = not na(sFT) and close <= sFT and close >= sFB

// ══════════════════════════════════════════════
// SCORE SYSTEM — 7 نقاط
// ══════════════════════════════════════════════
// LONG: Hunt DN → Disp UP → KZ → HTF Bull → SMC → FVG
lS1 = inKZ()                          ? 1 : 0  // NY Killzone
lS2 = mDn and not mUp and rangeOK     ? 1 : 0  // Hunt DN + Range كافٍ
lS3 = mDnC                            ? 1 : 0  // Hunt أغلق داخل النطاق ✅
lS4 = dspL                            ? 1 : 0  // Displacement صعودي
lS5 = htfBull                         ? 1 : 0  // أمس كان صاعداً
lS6 = hadSSS or bullCHoCH or bullBOS  ? 1 : 0  // SMC Structure
lS7 = inBFVG                          ? 1 : 0  // FVG Zone
longScore = lS1 + lS2 + lS3 + lS4 + lS5 + lS6 + lS7

// SHORT: Hunt UP → Disp DN → KZ → HTF Bear → SMC → FVG
sS1 = inKZ()                          ? 1 : 0
sS2 = mUp and not mDn and rangeOK     ? 1 : 0
sS3 = mUpC                            ? 1 : 0
sS4 = dspB                            ? 1 : 0
sS5 = htfBear                         ? 1 : 0
sS6 = hadBSS or bearCHoCH or bearBOS  ? 1 : 0
sS7 = inSFVG                          ? 1 : 0
shortScore = sS1 + sS2 + sS3 + sS4 + sS5 + sS6 + sS7

// ══════════════════════════════════════════════
// CONFIRMATION CANDLE
// ══════════════════════════════════════════════
bullConfirm = close > open and (open - low) > (high - close) * 0.5
bearConfirm = close < open and (high - open) > (close - low) * 0.5

// ══════════════════════════════════════════════
// ENTRY — إشارة واحدة يومياً
// ══════════════════════════════════════════════
longSig  = longScore  >= minScore and mDn and mDnC and bullConfirm and not todayDone and strategy.position_size == 0
shortSig = shortScore >= minScore and mUp and mUpC and bearConfirm and not todayDone and strategy.position_size == 0

if longSig
    todayDone := true
    _sl  = mLP - atrV * slM
    _rsk = close - _sl
    _tp1 = close + _rsk * tp1R
    _tp2 = close + _rsk * tp2R
    strategy.entry("LONG", strategy.long)
    strategy.exit("LX1", "LONG", qty_percent=50,  stop=_sl, limit=_tp1)
    strategy.exit("LX2", "LONG", qty_percent=100, stop=_sl, limit=_tp2)
    label.new(bar_index, low - atrV * 0.5,
              "🎯 LONG " + str.tostring(longScore) + "/7",
              color=color.new(color.green, 0), textcolor=color.white,
              style=label.style_triangleup, size=size.small)
    line.new(bar_index, _sl,  bar_index + 30, _sl,  color=color.red,   width=1, style=line.style_dashed)
    line.new(bar_index, _tp1, bar_index + 30, _tp1, color=color.green, width=1, style=line.style_dashed)
    line.new(bar_index, _tp2, bar_index + 30, _tp2, color=color.lime,  width=2)
    alert("🎯 AMD SNIPER LONG | " + syminfo.ticker + " | Score:" + str.tostring(longScore) + "/7 | @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar_close)

if shortSig
    todayDone := true
    _sl  = mHP + atrV * slM
    _rsk = _sl - close
    _tp1 = close - _rsk * tp1R
    _tp2 = close - _rsk * tp2R
    strategy.entry("SHORT", strategy.short)
    strategy.exit("SX1", "SHORT", qty_percent=50,  stop=_sl, limit=_tp1)
    strategy.exit("SX2", "SHORT", qty_percent=100, stop=_sl, limit=_tp2)
    label.new(bar_index, high + atrV * 0.5,
              "🎯 SHORT " + str.tostring(shortScore) + "/7",
              color=color.new(color.red, 0), textcolor=color.white,
              style=label.style_triangledown, size=size.small)
    line.new(bar_index, _sl,  bar_index + 30, _sl,  color=color.red,   width=1, style=line.style_dashed)
    line.new(bar_index, _tp1, bar_index + 30, _tp1, color=color.green, width=1, style=line.style_dashed)
    line.new(bar_index, _tp2, bar_index + 30, _tp2, color=color.lime,  width=2)
    alert("🎯 AMD SNIPER SHORT | " + syminfo.ticker + " | Score:" + str.tostring(shortScore) + "/7 | @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar_close)

alertcondition(longSig,  title="AMD SNIPER LONG",  message="🎯 LONG {{ticker}} @ {{close}} | AMD SNIPER")
alertcondition(shortSig, title="AMD SNIPER SHORT", message="🎯 SHORT {{ticker}} @ {{close}} | AMD SNIPER")

// ══════════════════════════════════════════════
// VISUALS
// ══════════════════════════════════════════════
bgcolor(inAsia() ? color.new(color.blue,  94) : na, title="Asia Session")
bgcolor(inKZ()   ? color.new(color.green, 92) : na, title="NY Open Killzone")

plot(asiaOk ? asiaH : na, "Asia H", color=color.blue, linewidth=1, style=plot.style_linebr)
plot(asiaOk ? asiaL : na, "Asia L", color=color.blue, linewidth=1, style=plot.style_linebr)

bgcolor(mUp and not mDn ? color.new(color.red,  93) : na, title="Hunt↑")
bgcolor(mDn and not mUp ? color.new(color.lime, 93) : na, title="Hunt↓")

plotshape(bssSweep, "BSS Sweep", shape.xcross, location.abovebar, color.red,  size=size.small)
plotshape(sssSweep, "SSS Sweep", shape.xcross, location.belowbar, color.lime, size=size.small)

if bullBOS
    label.new(bar_index, lastSH, "BOS↑",   color=color.green,  textcolor=color.white, style=label.style_label_left, size=size.tiny)
if bearBOS
    label.new(bar_index, lastSL, "BOS↓",   color=color.red,    textcolor=color.white, style=label.style_label_left, size=size.tiny)
if bullCHoCH
    label.new(bar_index, lastSH, "CHoCH↑", color=color.teal,   textcolor=color.white, style=label.style_label_left, size=size.tiny)
if bearCHoCH
    label.new(bar_index, lastSL, "CHoCH↓", color=color.orange, textcolor=color.white, style=label.style_label_left, size=size.tiny)

if mUp and not mUp[1]
    label.new(bar_index, high, "🔴 Hunt↑", color=color.red,  textcolor=color.white, style=label.style_label_down, size=size.small)
if mDn and not mDn[1]
    label.new(bar_index, low,  "🟢 Hunt↓", color=color.lime, textcolor=color.white, style=label.style_label_up,   size=size.small)

if bullFVG
    box.new(bar_index - 2, bFT, bar_index + 20, bFB, border_color=color.teal,   border_width=1, bgcolor=color.new(color.teal,   82))
if bearFVG
    box.new(bar_index - 2, sFT, bar_index + 20, sFB, border_color=color.orange, border_width=1, bgcolor=color.new(color.orange, 82))

// ══════════════════════════════════════════════
// INFO TABLE
// ══════════════════════════════════════════════
var table tbl = table.new(position.top_right, 2, 10,
                           border_color=color.gray, border_width=1,
                           bgcolor=color.new(color.black, 72))

if barstate.islast
    _sess = inAsia() ? "🌏 Asia" : inKZ() ? "🎯 NY Open KZ" : "⏸ Outside"
    _manip = mUp ? "🔴 Hunt↑" + (mUpC ? " ✅" : " ⏳") : mDn ? "🟢 Hunt↓" + (mDnC ? " ✅" : " ⏳") : "—"
    _htf   = htfBull ? "🟢 Bull" : htfBear ? "🔴 Bear" : "⚪ Neutral"
    _done  = todayDone ? "✅ أُرسلت" : "⏳ لا إشارة"
    _lsc   = str.tostring(longScore)  + "/7"
    _ssc   = str.tostring(shortScore) + "/7"

    table.cell(tbl, 0, 0, "AMD SNIPER", bgcolor=color.new(color.navy, 20), text_color=color.white, text_halign=text.align_center)
    table.cell(tbl, 1, 0, _sess,        bgcolor=color.new(color.navy, 20), text_color=color.white)
    table.cell(tbl, 0, 1, "Hunt",       text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 1, _manip,       text_color=mUp ? color.red : mDn ? color.lime : color.gray)
    table.cell(tbl, 0, 2, "HTF Bias",   text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 2, _htf,         text_color=htfBull ? color.green : htfBear ? color.red : color.gray)
    table.cell(tbl, 0, 3, "Asia H",     text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 3, asiaOk ? str.tostring(asiaH, "#.##") : "—", text_color=color.blue)
    table.cell(tbl, 0, 4, "Asia L",     text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 4, asiaOk ? str.tostring(asiaL, "#.##") : "—", text_color=color.blue)
    table.cell(tbl, 0, 5, "Long  Score",text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 5, _lsc,         text_color=longScore  >= minScore ? color.green : color.gray)
    table.cell(tbl, 0, 6, "Short Score",text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 6, _ssc,         text_color=shortScore >= minScore ? color.red   : color.gray)
    table.cell(tbl, 0, 7, "ATR",        text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 7, str.tostring(atrV, "#.####"), text_color=color.white)
    table.cell(tbl, 0, 8, "Today",      text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 8, _done,        text_color=todayDone ? color.green : color.gray)
    table.cell(tbl, 0, 9, "Use TF",     text_color=color.gray, text_halign=text.align_left)
    table.cell(tbl, 1, 9, "15m ← أفضل", text_color=color.yellow)
