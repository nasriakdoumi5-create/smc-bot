// @version=5
strategy("VWAP Bounce — NQ+ES | ADX Filter | v3",
     overlay=true,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     initial_capital=50000,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=5)

// ══ إعدادات ════════════════════════════════════════
rr      = input.float(1.5, "نسبة RR", step=0.5)
atrPer  = input.int(14,   "ATR Period")
rsiPer  = input.int(14,   "RSI Period")
adxPer  = input.int(14,   "ADX Period")

// ══ فلتر الجلسة UTC ════════════════════════════════
h         = hour(time, "UTC")
m         = minute(time, "UTC")
totalMins = h * 60 + m
inLondon  = totalMins >= 420 and totalMins < 720
inNY      = totalMins >= 810 and totalMins < 930
inSession = inLondon or inNY

// ══ VWAP ═══════════════════════════════════════════
vwapVal = ta.vwap(hlc3)

// ══ ATR ════════════════════════════════════════════
atrVal  = ta.atr(atrPer)
atrAvg  = ta.ema(atrVal, 20)

// ══ RSI ════════════════════════════════════════════
rsiVal  = ta.rsi(close, rsiPer)

// ══ ADX — Market Regime ════════════════════════════
[diPlus, diMinus, adxVal] = ta.dmi(adxPer, adxPer)
isBullTrend = adxVal > 25 and diPlus  > diMinus
isBearTrend = adxVal > 25 and diMinus > diPlus

// ══ HTF Bias — EMA21 / EMA50 على 1H ═══════════════
ema21_1h = request.security(syminfo.tickerid, "60", ta.ema(close, 21), lookahead=barmerge.lookahead_off)
ema50_1h = request.security(syminfo.tickerid, "60", ta.ema(close, 50), lookahead=barmerge.lookahead_off)
htfBull  = ema21_1h > ema50_1h
htfBear  = ema21_1h < ema50_1h

// ══ VWAP Bounce LONG ═══════════════════════════════
wasBelow  = low[1] < vwapVal[1] * 1.001 or low[2] < vwapVal[2] * 1.001
touchedDn = math.min(low[1], low[2], low[3]) <= vwapVal * 1.003
vwapLong  = (wasBelow or touchedDn) and close >= vwapVal * 0.999

// ══ VWAP Bounce SHORT ══════════════════════════════
wasAbove  = high[1] > vwapVal[1] * 0.999 or high[2] > vwapVal[2] * 0.999
touchedUp = math.max(high[1], high[2], high[3]) >= vwapVal * 0.997
vwapShort = (wasAbove or touchedUp) and close <= vwapVal * 1.001

// ══ شمعة ارتداد قوية ═══════════════════════════════
bodyPct   = math.abs(close - open) / (high - low + 0.001)
bounceBull = close > open and bodyPct > 0.50
bounceBear = close < open and bodyPct > 0.50

// ══ RSI على شمعات التراجع ══════════════════════════
minRsi   = math.min(rsiVal[1], rsiVal[2], rsiVal[3])
maxRsi   = math.max(rsiVal[1], rsiVal[2], rsiVal[3])
rsiLong  = minRsi < 48
rsiShort = maxRsi > 52

// ══ فلاتر ══════════════════════════════════════════
notChoppy = atrVal > atrAvg * 0.55
normalATR = atrVal < atrAvg * 2.0
noSpike   = math.abs(close[1] - close[4]) < atrVal * 2.5

// ══ قرار الدخول ════════════════════════════════════
longOk  = htfBull and vwapLong  and bounceBull and rsiLong  and notChoppy and normalATR and noSpike and not isBearTrend and inSession
shortOk = htfBear and vwapShort and bounceBear and rsiShort and notChoppy and normalATR and noSpike and not isBullTrend and inSession

// ══ مستويات الصفقة ═════════════════════════════════
recentLow  = math.min(low[1],  low[2],  low[3])
recentHigh = math.max(high[1], high[2], high[3])

longSL    = math.min(recentLow,  vwapVal) - atrVal * 0.3
shortSL   = math.max(recentHigh, vwapVal) + atrVal * 0.3
longRisk  = close - longSL
shortRisk = shortSL - close
longTP    = close + longRisk  * rr
shortTP   = close - shortRisk * rr
longBE    = close + longRisk  * 0.7
shortBE   = close - shortRisk * 0.7

validL = longOk  and longRisk  > atrVal * 0.3 and longRisk  < atrVal * 2.5
validS = shortOk and shortRisk > atrVal * 0.3 and shortRisk < atrVal * 2.5

// ══ تنفيذ الصفقات ══════════════════════════════════
if validL and strategy.position_size == 0
    strategy.entry("LONG", strategy.long)
    strategy.exit("XL", "LONG", stop=longSL, limit=longTP)

if validS and strategy.position_size == 0
    strategy.entry("SHORT", strategy.short)
    strategy.exit("XS", "SHORT", stop=shortSL, limit=shortTP)

// ══ رسم VWAP ═══════════════════════════════════════
plot(vwapVal,  "VWAP",     color=color.yellow,               linewidth=2)
plot(ema21_1h, "EMA21 1H", color=color.new(color.green, 40), linewidth=1)
plot(ema50_1h, "EMA50 1H", color=color.new(color.red,   40), linewidth=1)

// ══ إشارات LONG / SHORT ════════════════════════════
plotshape(validL, "LONG",  shape.labelup,   location.belowbar, color.new(color.green, 0), text="▲ L", textcolor=color.white, size=size.small)
plotshape(validS, "SHORT", shape.labeldown, location.abovebar, color.new(color.red,   0), text="▼ S", textcolor=color.white, size=size.small)

// ══ خلفية الجلسة ═══════════════════════════════════
bgcolor(inSession ? color.new(color.blue, 93) : na, title="Killzone")

// ══ جدول المعلومات ═════════════════════════════════
var table t = table.new(position.top_right, 2, 5, border_width=1, border_color=color.gray)
if barstate.islast
    regime    = isBullTrend ? "BULL ▲" : isBearTrend ? "BEAR ▼" : "RANGING ↔"
    regColor  = isBullTrend ? color.green : isBearTrend ? color.red : color.gray
    sesColor  = inSession ? color.green : color.gray
    sesLabel  = inSession ? "✅ KZ ON" : "🌙 OFF"
    table.cell(t, 0, 0, "Regime",  text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 1, 0, regime,    text_color=color.white, bgcolor=regColor,   text_size=size.small)
    table.cell(t, 0, 1, "ADX",     text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(math.round(adxVal, 1)), text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 0, 2, "RSI",     text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(math.round(rsiVal, 1)), text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 0, 3, "VWAP",    text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(math.round(vwapVal, 2)), text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 0, 4, "Session", text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(t, 1, 4, sesLabel,  text_color=color.white, bgcolor=sesColor,   text_size=size.small)
